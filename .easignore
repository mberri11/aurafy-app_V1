# EAS Build project archive — overrides .gitignore for what gets uploaded to the
# build server. .gitignore excludes assets/ (to keep local design-reference-style
# clutter out of git), but assets/ contains the icon/splash/sounds the app actually
# needs at build+runtime — so unlike .gitignore, we deliberately DO NOT ignore it here.

# dependencies
node_modules/
design-reference/
docs/
