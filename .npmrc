# Keep this app standalone — do not attach to any parent pnpm workspace.
ignore-workspace=true

# ============================================================================
# SECURITY: Minimum release age for npm packages (supply-chain attack defense)
# ============================================================================
# Require any npm package version to have been published for at least 1 day
# (1440 minutes) before pnpm allows installing it. Malicious npm releases are
# usually pulled within hours, so this provides a strong safety buffer.
# Do not disable. If urgently needed, add the package to minimumReleaseAgeExclude.
# ============================================================================
minimumReleaseAge: 1440
